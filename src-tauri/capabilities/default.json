{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-start-dragging",
    "core:window:allow-is-visible",

    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-register",

    {"allow": [{"path": "$APPDATA"}], "identifier": "fs:allow-mkdir"},
    {"allow": [{"path": "$APPDATA/**"}, {"path": "$APPDATA"}], "identifier": "fs:allow-exists"},
    {"allow": [{"path": "$APPDATA/**"}], "identifier": "fs:allow-write-text-file"},
    {"allow": [{"path": "$APPDATA/**"}], "identifier": "fs:allow-read-text-file"}
  ]
}
