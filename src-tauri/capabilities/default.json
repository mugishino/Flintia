{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {"identifier": "opener:allow-open-url", "allow": [{"url": "https://www.google.com/search?q=*"}]},

    "core:window:allow-is-visible",
    "core:window:allow-inner-size",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:webview:allow-create-webview-window",

    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-register",

    "dialog:allow-open",
    "dialog:allow-save",

    "notification:default",

    {"identifier": "opener:allow-open-path", "allow": [{
      "path": "$APPDATA"
    }]},
    {"identifier": "shell:allow-execute", "allow": [
      {"args": true, "name": "nvidia-smi", "cmd": "nvidia-smi"},
      {"args": true, "name": "ffmpeg", "cmd": "ffmpeg"},
      {"args": true, "name": "nvcc", "cmd": "nvcc"},
      {"args": true, "name": "where", "cmd": "where"}
    ]},

    {"allow": [{"path": "$APPDATA"}], "identifier": "fs:allow-mkdir"},
    {"allow": [{"path": "$APPDATA/**"}], "identifier": "fs:allow-mkdir"},
    {"allow": [{"path": "$APPDATA/**"}], "identifier": "fs:allow-write-text-file"},
    {"allow": [{"path": "**"}], "identifier": "fs:allow-exists"},
    {"allow": [{"path": "**"}], "identifier": "fs:allow-write-file"},
    {"allow": [{"path": "**"}], "identifier": "fs:allow-read-text-file"},
    {"allow": [{"path": "**"}], "identifier": "fs:allow-read-dir"}
  ]
}
