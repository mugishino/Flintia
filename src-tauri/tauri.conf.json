{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flintia",
  "version": "2.4.2",
  "identifier": "com.flintia.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flintia",
        "width": 540,
        "height": 720,
        "center": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
